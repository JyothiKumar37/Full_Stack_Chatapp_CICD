# Copy this file to .env and adjust the values before running `docker compose up`.
#   cp .env.example .env
# The values below are working defaults — change the secrets before any real deployment.

# --- MongoDB ---
# Root credentials. Used both to initialize the mongo container and to build
# the backend's MONGODB_URI connection string in docker-compose.yml.
MONGO_USERNAME=mongoadmin
MONGO_PASSWORD=1b2282dab4cd946e9b3ca17304d1381e

# --- Backend ---
# Secret used to sign JWT auth cookies. Generate your own with:
#   openssl rand -base64 48
JWT_SECRET=eqIlHryfBp2N/bF5fZVROJOltc5+ci5Kqc9ML/K2Hd4N3VPI2dmb4MMkIbEtMufM

# Origins allowed by the REST API + Socket.io CORS.
#   *            -> reflect the request's own origin (works with any host/IP).
#                   Best when the EC2 public IP changes on stop/start, since the
#                   app is served same-origin behind nginx anyway.
#   host1,host2  -> lock to an explicit comma-separated list, e.g.
#                   http://13.201.184.214,http://localhost
CORS_ORIGINS=*

# --- Frontend ---
# Host port the frontend (nginx) is published on.
FRONTEND_PORT=80

# Note: images (profile pics + message attachments) are stored inline in
# MongoDB as base64 data URLs — no external image service required.
